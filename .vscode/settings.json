{
  "typescript.tsdk": "node_modules/.pnpm/typescript@5.1.3/node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,

  "tailwindCSS.experimental.classRegex": [
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]", "cn\\(([^)]*)\\)", "tw\\(([^)]*)\\)"]
  ],

  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": true,
    "source.addMisingImports": true,
  },

  "eslint.options": {
    "extensions": [".js", ".jsx", ".md", ".mdx", ".ts", ".tsx"]
  },
  "eslint.validate": [
    "markdown",
    "mdx",
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],

  "mdx.server.enable": true,

  "explorer.fileNesting.patterns": {
    "next.config.*": ".env*, contentlayer.config.*, package.json, prettier.config.cjs, postcss.config.cjs, next-env.*, tailwind.config.ts, tsconfig.json, .prettierrc.*, .eslintrc.*, .gitignore, README.md"
  }
}